### Character Limit Enforcement

**50,000 Character Limit:**
```kotlin
fun truncateLogIfNeeded(logContent: String, maxLength: Int = 50000): String {
    return if (logContent.length > maxLength) {
        val truncated = logContent.take(maxLength - 100)
        val suffix = "\n\n... (log truncated, ${logContent.length - maxLength} characters removed)"
        truncated + suffix
    } else {
        logContent
    }
}

// Before updating subtask
val finalLog = truncateLogIfNeeded(progressLog.joinToString("\n"))
update_subtask(id, finalLog)
```

