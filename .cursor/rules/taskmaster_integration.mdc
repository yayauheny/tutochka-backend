### Filtering Tasks Locally

**Filter by status:**
```kotlin
val pendingTasks = tasksArray?.filter { 
    it.jsonObject["status"]?.jsonPrimitive?.content == "pending" 
} ?: emptyList()

val inProgressTasks = tasksArray?.filter { 
    it.jsonObject["status"]?.jsonPrimitive?.content == "in-progress" 
} ?: emptyList()
```

**Filter by priority:**
```kotlin
val highPriorityTasks = tasksArray?.filter { 
    it.jsonObject["priority"]?.jsonPrimitive?.content == "high" 
} ?: emptyList()
```

**Filter by dependencies (all dependencies done):**
```kotlin
fun getTasksWithDependenciesSatisfied(tasksArray: JsonArray): List<JsonElement> {
    val taskMap = tasksArray.associateBy { 
        it.jsonObject["id"]?.jsonPrimitive?.content ?: "" 
    }
    
    return tasksArray.filter { task ->
        val deps = task.jsonObject["dependencies"]?.jsonArray?.map { 
            it.jsonPrimitive.content 
        } ?: emptyList()
        
        deps.all { depId ->
            val depTask = taskMap[depId]
            depTask?.jsonObject["status"]?.jsonPrimitive?.content == "done"
        }
    }
}
```

**Filter by tag:**
```kotlin
fun getTasksByTag(tag: String = "master"): JsonArray? {
    val tasksJsonContent = read_file(".taskmaster/tasks/tasks.json")
    val json = Json.parseToJsonElement(tasksJsonContent)
    return json.jsonObject[tag]?.jsonObject?.get("tasks")?.jsonArray
}
```

### Caching Strategy

**In-Memory Cache Pattern:**
```kotlin
// Session-level cache (initialize once per session)
var cachedTasksJson: JsonObject? = null
var cacheTimestamp: Long = 0
val CACHE_TTL_MS = 60000 // 1 minute

fun getCachedTasks(tag: String = "master"): JsonArray? {
    val now = System.currentTimeMillis()
    
    if (cachedTasksJson == null || (now - cacheTimestamp) > CACHE_TTL_MS) {
        val tasksJsonContent = read_file(".taskmaster/tasks/tasks.json")
        cachedTasksJson = Json.parseToJsonElement(tasksJsonContent).jsonObject
        cacheTimestamp = now
    }
    
    return cachedTasksJson?.get(tag)?.jsonObject?.get("tasks")?.jsonArray
}

// Use cached data for reads
val tasks = getCachedTasks("master")
val task = tasks?.firstOrNull { /* filter */ }
```

