# Cursor AI - Ignore sensitive and unnecessary files
# This file prevents Cursor from indexing and including these files in AI context

# =============================================================================
# Environment Variables & Secrets
# =============================================================================
.env
.env.*
!.env.example
!.env.template
*.env
*.secret
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
*.truststore

# Docker environment files
docker/.env
docker/.env.*
docker/env.local
docker/env.production
docker/env.staging

# =============================================================================
# Credentials & API Keys
# =============================================================================
**/credentials.json
**/secrets.json
**/api-keys.json
**/config/secrets.*
**/config/credentials.*
*.credentials
*.secrets

# =============================================================================
# Database & Connection Strings
# =============================================================================
**/database.properties
**/db.properties
**/datasource.properties
**/*.db
**/*.sqlite
**/*.sqlite3

# =============================================================================
# SSL/TLS Certificates & Keys
# =============================================================================
*.crt
*.cert
*.cer
*.key
*.csr
*.pem
*.p7b
*.p7c
*.p12
*.pfx
**/ssl/
**/certs/
**/certificates/

# =============================================================================
# HashiCorp Vault
# =============================================================================
vault-token
.vault-token
vault.hcl.local
vault.json.local
**/vault-secrets.*
**/.vault/

# =============================================================================
# Logs & Temporary Files
# =============================================================================
*.log
logs/
*.tmp
*.temp
*.swp
*.swo
*~

# =============================================================================
# Build Artifacts (already in .gitignore, but ensure Cursor ignores too)
# =============================================================================
build/
dist/
target/
out/
*.jar
*.war
*.ear
*.class

# =============================================================================
# IDE & Editor Files
# =============================================================================
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store

# =============================================================================
# Node modules (if any)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Docker volumes & data
# =============================================================================
docker/data/
docker/volumes/
**/caddy_data/

# =============================================================================
# Backup files
# =============================================================================
*.bak
*.backup
*.old
*_backup
*_backup_*

# =============================================================================
# Task Master sensitive files
# =============================================================================
.taskmaster/docs/*.txt
.taskmaster/docs/*.md
!.taskmaster/README.md
!.taskmaster/templates/

