# TuTochka Environment Configuration
# Copy this file to .env and modify the values as needed

# Database Configuration (for application)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=admin
DB_PASSWORD=admin
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Application Configuration
APP_PORT=8080
APP_ENV=production
TZ=UTC

# Telegram Webhook Security
BOT_WEBHOOK_SECRET_TOKEN=change-me-to-a-random-secret

# PostgreSQL Container Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=postgres
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C

# PostgreSQL Performance Tuning
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=384MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WORK_MEM=4MB
POSTGRES_RANDOM_PAGE_COST=1.1
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_WAL_BUFFERS=16MB
POSTGRES_DEFAULT_STATISTICS_TARGET=100
POSTGRES_MAX_WAL_SIZE=2GB
POSTGRES_MIN_WAL_SIZE=1GB

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/logs

# Docker Compose Network
COMPOSE_PROJECT_NAME=tutochka
COMPOSE_NETWORK_NAME=tutochka_network
